R""(#version 330 core

out vec2 outUVCoords;

void main()
{
    // Generate a triangle to draw on it
    float x = -1.0 + float((gl_VertexID & 1) << 2);
    float y = -1.0 + float((gl_VertexID & 2) << 1);

    outUVCoords = vec2(x * 0.5 + 0.5, y * 0.5 + 0.5);
    gl_Position = vec4(x, y, 0.0, 1.0);
}
)""